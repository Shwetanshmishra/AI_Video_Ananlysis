# ── LLM ──
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Sarvam (hinglish transcription) ──
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_STT_MODEL=saaras:v2.5

# ── Whisper ──
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── yt-dlp (optional) ──
YT_DLP_PROXY=
YT_DLP_COOKIES_FILE=

# ── CORS ──
ALLOWED_ORIGINS=*

# ── Frontend -> backend ──
BACKEND_URL=http://localhost:8000
